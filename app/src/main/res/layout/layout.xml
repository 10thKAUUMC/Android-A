<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:scrollbarSize="18dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textView11"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="부글부글 화가 나요"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.502"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivStampAngry" />

    <TextView
        android:id="@+id/textView10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="생각이 많아지고 불안해요"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivStampSad" />

    <TextView
        android:id="@+id/textView9"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="평범한 하루였어요"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivStampNeutral" />

    <TextView
        android:id="@+id/textView8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="들뜨고 흥분돼요"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivStampSmile" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_stamps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="898dp" />

    <ImageView
        android:id="@+id/ivStampLaugh"
        android:layout_width="40dp"
        android:layout_height="45dp"
        android:layout_marginTop="264dp"
        android:src="@drawable/group_573"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivStampSmile"
        android:layout_width="40dp"
        android:layout_height="45dp"
        android:layout_marginTop="46dp"
        android:src="@drawable/group_574"
        app:layout_constraintStart_toStartOf="@id/ivStampLaugh"
        app:layout_constraintTop_toBottomOf="@id/ivStampLaugh" />

    <ImageView
        android:id="@+id/ivStampNeutral"
        android:layout_width="40dp"
        android:layout_height="45dp"
        android:layout_marginTop="46dp"
        android:src="@drawable/group_575"
        app:layout_constraintStart_toStartOf="@id/ivStampSmile"
        app:layout_constraintTop_toBottomOf="@id/ivStampSmile" />

    <ImageView
        android:id="@+id/ivStampSad"
        android:layout_width="40dp"
        android:layout_height="45dp"
        android:layout_marginTop="46dp"
        android:src="@drawable/group_576"
        app:layout_constraintStart_toStartOf="@id/ivStampNeutral"
        app:layout_constraintTop_toBottomOf="@id/ivStampNeutral" />

    <ImageView
        android:id="@+id/ivStampAngry"
        android:layout_width="40dp"
        android:layout_height="45dp"
        android:layout_marginTop="46dp"
        android:src="@drawable/group_462"
        app:layout_constraintStart_toStartOf="@id/ivStampSad"
        app:layout_constraintTop_toBottomOf="@id/ivStampSad" />


    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="100dp"
        android:text="오늘 하루는 어땠나요?"
        android:textSize="30dp"
        android:textStyle="bold|italic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView5"
        android:layout_width="229dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="감정우표를 선택해주세요"
        android:textSize="22sp"
        android:textStyle="bold|italic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

    <TextView
        android:id="@+id/textView6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="선택하신 감정우표를 기반으로 맞춤형 질문이 배달됩니다"
        android:textSize="8sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView5" />

    <ImageButton
        android:id="@+id/imageButton"
        android:layout_width="8dp"
        android:layout_height="14dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="26dp"
        android:src="@drawable/vector"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="더없이 행복한 하루였어요"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivStampLaugh" />

</androidx.constraintlayout.widget.ConstraintLayout>