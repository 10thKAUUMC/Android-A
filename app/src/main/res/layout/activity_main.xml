<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    tools:layout_editor_absoluteX="204dp"
    tools:layout_editor_absoluteY="-1dp">

    <TextView
        android:id="@+id/underText5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="부글부글 화가 나요"
        tools:layout_editor_absoluteX="174dp"
        tools:layout_editor_absoluteY="655dp" />

    <TextView
        android:id="@+id/textViewTitle"
        android:layout_width="167dp"
        android:layout_height="56dp"
        android:scaleX="2"
        android:scaleY="2"
        android:text="오늘 하루는 어땠나요?"
        tools:layout_editor_absoluteX="178dp"
        tools:layout_editor_absoluteY="146dp" />

    <TextView
        android:id="@+id/textViewSubtitle2"
        android:layout_width="318dp"
        android:layout_height="36dp"
        android:scaleX="0.9"
        android:scaleY="0.9"
        android:text="선택한 감정우표를 기반으로 맞춤형 질문이 배달됩니다"
        tools:layout_editor_absoluteX="54dp"
        tools:layout_editor_absoluteY="234dp" />

    <TextView
        android:id="@+id/textViewSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleX="1.2"
        android:scaleY="1.2"
        android:text="감정 우표를 선택해주세요"
        tools:layout_editor_absoluteX="137dp"
        tools:layout_editor_absoluteY="181dp" />

    <ImageButton
        android:id="@+id/happyButton"
        android:layout_width="42dp"
        android:layout_height="42dp"
        app:srcCompat="@drawable/ic_happy"
        tools:layout_editor_absoluteX="205dp"
        tools:layout_editor_absoluteY="304dp" />

    <ImageButton
        android:id="@+id/normalButton"
        android:layout_width="42dp"
        android:layout_height="42dp"
        app:srcCompat="@drawable/ic_normal"
        tools:layout_editor_absoluteX="205dp"
        tools:layout_editor_absoluteY="463dp" />

    <ImageButton
        android:id="@+id/nervousButton"
        android:layout_width="42dp"
        android:layout_height="42dp"
        app:srcCompat="@drawable/ic_nervous"
        tools:layout_editor_absoluteX="205dp"
        tools:layout_editor_absoluteY="530dp" />

    <ImageButton
        android:id="@+id/badButton"
        android:layout_width="42dp"
        android:layout_height="42dp"
        app:srcCompat="@drawable/ic_bad"
        tools:layout_editor_absoluteX="205dp"
        tools:layout_editor_absoluteY="603dp" />

    <ImageButton
        android:id="@+id/excitingButton"
        android:layout_width="42dp"
        android:layout_height="42dp"
        app:srcCompat="@drawable/ic_exciting"
        tools:layout_editor_absoluteX="205dp"
        tools:layout_editor_absoluteY="385dp" />

    <TextView
        android:id="@+id/underText1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="더없이 행복한 하루였어요"
        tools:layout_editor_absoluteX="147dp"
        tools:layout_editor_absoluteY="355dp" />

    <TextView
        android:id="@+id/underText2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="들뜨고 흥분돼요"
        tools:layout_editor_absoluteX="174dp"
        tools:layout_editor_absoluteY="434dp" />

    <TextView
        android:id="@+id/underText3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="평범한 하루였어요"
        tools:layout_editor_absoluteX="161dp"
        tools:layout_editor_absoluteY="492dp" />

    <TextView
        android:id="@+id/underText4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="생각이 많아지고 불안해요"
        tools:layout_editor_absoluteX="147dp"
        tools:layout_editor_absoluteY="572dp" />

</androidx.constraintlayout.widget.ConstraintLayout>