<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="8dp">


        <ImageView
            android:id="@+id/itemImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_shoe1" />

        <TextView
            android:id="@+id/itemState"
            app:layout_constraintTop_toBottomOf="@id/itemImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TextView"
            android:textColor="#FC5100" />

        <TextView
            android:id="@+id/itemTitle"
            app:layout_constraintTop_toBottomOf="@id/itemState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Air Jordan XXXVI"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/itemTitle2"
            app:layout_constraintTop_toBottomOf="@id/itemTitle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="US$185"
            android:textColor="#c6c6c6" />

        <TextView
            android:id="@+id/itemTitle3"
            app:layout_constraintTop_toBottomOf="@id/itemTitle2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TextView" />

        <ImageView
            android:id="@+id/wishButton"
            app:layout_constraintTop_toTopOf="@id/itemImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/ic_heatr_off"
            app:layout_constraintRight_toRightOf="@id/itemImage"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>